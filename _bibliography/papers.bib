@unpublished{wang2026punishment,
  title     = {Punishment on Demand: Using Transformer Surprisal to Time Peer Sanctions in Repeated Public Goods Games},
  author    = {Wang, Duo},
  year      = {2026},
  note      = {Working paper},
  abstract  = {This paper investigates whether language-based monitoring can improve the efficiency of peer punishment in sustaining cooperation. Using transformer-based surprisal scores to detect unexpected behavioral shifts, the adaptive approach achieves a cooperation rate of 0.763 compared to 0.695 under always-on punishment, while reducing enforcement costs from 306 to 132 punishment points.},
  selected  = {true},
  bibtex_show = {true}
}
